# Copy this file to `.env` and fill in PGPASSWORD and the ENTRA_* values.
# `.env` is git-ignored — never commit real credentials.

# HTTP server
PORT=3000
# Comma-separated. admin runs on 5173, liff on 5174.
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# How many reverse proxies sit in front of this server. 0 in dev, where nothing
# does. Behind one load balancer it is 1, behind a CDN in front of a balancer, 2.
# The rate limiter identifies callers by IP and reads it through this: set it too
# low and everyone shares one bucket, too high and the header can be forged.
TRUST_PROXY=0

# Microsoft Entra ID — from the app registration's Overview page. Both are
# required: the server refuses to start without them, because a default tenant
# or audience would mean accepting tokens it should reject.
#
# Neither is secret (the same two values ship inside admin's bundle), but the
# app registration must have accessTokenAcceptedVersion: 2 in its manifest or
# every token will fail the issuer check.
ENTRA_TENANT_ID=
# Application (client) ID. Also the expected `aud` on incoming access tokens.
ENTRA_API_CLIENT_ID=

# LINE — from the LINE Developers Console.
#
# The Channel ID of the *Login channel* that the LIFF app belongs to (Basic
# settings tab). It is the numeric part of the LIFF ID: a LIFF ID of
# 1234567890-abcdEFGH belongs to channel 1234567890. Sent to LINE when verifying
# an ID token, which is how LINE knows to reject tokens minted for someone else.
# Not a secret. The Channel *Secret* is not needed and must never be added here
# with a VITE_ prefix anywhere.
LINE_CHANNEL_ID=

# Signing key for the sessions issued to liff/. This one IS a secret: anyone who
# has it can mint a session for any employee. At least 32 characters, and a
# different value in every environment. Generate one with:
#   openssl rand -base64 32
SESSION_JWT_SECRET=

# PostgreSQL — these names are the libpq standard, so `pg` picks them up directly.
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=
PGDATABASE=hrm_dev
