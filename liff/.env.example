# Copy this file to `.env` and fill in VITE_LIFF_ID.
# `.env` is git-ignored — never commit real IDs.

# LIFF app ID from the LINE Developers Console (Login channel → LIFF tab).
# Looks like 1234567890-abcdEFGH. Note this is the LIFF ID, not the Channel ID.
#
# Anything prefixed VITE_ is inlined into the client bundle and is therefore
# public. That is fine for the LIFF ID, which is not a secret — but it means the
# Channel Secret must never be given a VITE_ prefix. It belongs in server/.env.
VITE_LIFF_ID=
