# Copy this file to `.env` and fill in the values from the Entra app registration.
# `.env` is git-ignored.
#
# Everything here is public by design — it is inlined into the bundle, and OAuth
# for a single-page app has no client secret to keep. A secret would be useless
# anyway: anyone can read the bundle. What actually protects the API is the
# server verifying the token's signature, not the client keeping these quiet.
#
# The same registration backs both this app and the API, so VITE_ENTRA_TENANT_ID
# and VITE_ENTRA_CLIENT_ID are the same two values as ENTRA_TENANT_ID and
# ENTRA_API_CLIENT_ID in server/.env.

VITE_ENTRA_TENANT_ID=
VITE_ENTRA_CLIENT_ID=

# The scope exposed under "Expose an API". Substitute the client ID above.
VITE_ENTRA_API_SCOPE=api://<client-id>/access_as_user
